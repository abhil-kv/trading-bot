# Port the Express API listens on
PORT=4000

# Comma separated list of origins allowed to call this API (your React dev server)
CLIENT_ORIGIN=http://localhost:5173

# Secret used to sign the session cookie. Use a long random string in real use.
SESSION_SECRET=change-this-to-a-long-random-string

# Set to "true" when serving the API over HTTPS in production
COOKIE_SECURE=false

# How often (ms) the Nifty50 instrument master file is refreshed from Angel One
INSTRUMENT_MASTER_TTL_MS=86400000

# Minimum gap (ms) between two live calls to Angel One's quote API.
# Protects you from hitting their rate limit when several browser tabs poll at once.
QUOTE_CACHE_TTL_MS=3000

# Marketaux API key for fetching market news
# Get your free API key from https://www.marketaux.com/
MARKETAUX_API_KEY=your_marketaux_api_key_here
